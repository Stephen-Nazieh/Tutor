# Database (required for npm run dev - use Docker: npm run docker:up or npm run initialize)
DATABASE_URL=postgresql://tutorme:tutorme_password@localhost:5433/tutorme
DIRECT_URL=postgresql://tutorme:tutorme_password@localhost:5433/tutorme

# NextAuth (required for auth)
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars
NEXTAUTH_URL=http://localhost:3003

# Redis (optional - enables shared rate limiting, session caching)
REDIS_URL=redis://localhost:6379

# Email Configuration for Namecheap/PrivateEmail
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@solocorn.co
SMTP_PASS=your-email-password-here
CONTACT_EMAIL=support@solocorn.co

# ADK Service Configuration
# The URL of your deployed ADK service (from services/adk/)
ADK_BASE_URL=https://your-adk-service-url.run.app
ADK_AUTH_TOKEN=your-adk-auth-token-here

# AI Provider API Keys (used directly when ADK service is not available)
KIMI_API_KEY=your-kimi-api-key
GEMINI_API_KEY=your-gemini-api-key
