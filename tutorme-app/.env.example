# Email Configuration for Namecheap/PrivateEmail
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@solocorn.co
SMTP_PASS=your-email-password-here
CONTACT_EMAIL=support@solocorn.co

# ADK Service Configuration
# The URL of your deployed ADK service (from services/adk/)
ADK_BASE_URL=https://your-adk-service-url.run.app
ADK_AUTH_TOKEN=your-adk-auth-token-here

# AI Provider API Keys (used directly when ADK service is not available)
KIMI_API_KEY=your-kimi-api-key
GEMINI_API_KEY=your-gemini-api-key
